# MongoDB Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/
DB_NAME=smai_auth

# Secret Key for Fernet Encryption (Must be 32-byte base64 encoded)
# You can generate one using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=your-32-byte-base64-key-here

# Base URL for the responses
BASE_URL=http://localhost:8080
